# ─────────────────────────────────────────────────────────────────────────────
# Vesna Affidavit — пример переменных окружения для Vercel
# Скопируй в Vercel → Project → Settings → Environment Variables.
# НИКОГДА не коммить реальные значения (репозиторий на GitHub).
# ─────────────────────────────────────────────────────────────────────────────

# Telegram — доставка подписанного PDF
TELEGRAM_BOT_TOKEN=000000000:AA__replace_me__
TELEGRAM_CHAT_ID=
# (опц.) id топика/треда для аффидевитов
TG_THREAD_AFFIDAVIT=

# Общий секрет API: фронт шлёт его, сервер сверяет (защита /api/send-telegram)
AFFIDAVIT_SECRET=__replace_with_random_string__

# Resend — email-копия PDF клиенту
RESEND_API_KEY=re___replace_me__
REPORT_EMAIL=vesna.report@vesnatattoo.com

# (опц.) Make.com webhook для источников/CRM
MAKE_SOURCES=
